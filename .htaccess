RewriteEngine On
RewriteBase /

# 1. ASSET FIX: Kisi bhi folder se _next ya images mangi jaye, root pe bhej do
# Yeh aapke console ke red errors ko 100% khatam kar dega
RewriteRule ^.*/(_next/.*)$ /$1 [L,QSA,R=301]
RewriteRule ^.*/(images/.*)$ /$1 [L,QSA,R=301]

# 2. Directory Indexing Fix
# Agar user /community/ par jaye to community/index.html load karo
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ $1/index.html [L]

# 3. Clean URLs Fix
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]